{
  "id": "daily-music-topic",
  "name": "\u6bcf\u65e5\u97f3\u4e50\u9009\u9898",
  "category": "\u8d44\u8baf\u7c7b",
  "type": "service",
  "status": "stopped",
  "summary": "Auto-generate music topics and send daily email from a Windows background service.",
  "description": "This is the production mode for MusicNews. After startup, it stays alive in the Windows background, keeps the 9:00 daily send schedule, and still supports preview checks and history viewing in dashboard.",
  "path": "E:/Project/codex/MusicNews",
  "entry": "",
  "health": "http://127.0.0.1:4332/health",
  "integration": "project-config",
  "control": {
    "enabled": true,
    "type": "service",
    "actions": ["test", "run", "stop"],
    "testCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/test.ps1"]
    },
    "runCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/run.ps1"]
    },
    "stopCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-WindowStyle", "Hidden", "-ExecutionPolicy", "Bypass", "-File", "scripts/stop.ps1"]
    },
    "processMatch": {
      "name": "python.exe",
      "commandLinePattern": "*service.py*"
    },
    "startupProbe": {
      "initialDelayMs": 1000,
      "attempts": 12,
      "intervalMs": 1000
    }
  },
  "paths": {
    "logs": "logs",
    "output": "output",
    "data": "data"
  },
  "reports": {
    "runHistory": {
      "label": "\u8fd0\u884c\u65e5\u5fd7",
      "type": "music-topic-history",
      "path": "output"
    }
  },
  "timeline": [
    {
      "time": "\u4eca\u5929",
      "title": "\u63a5\u5165\u771f\u5b9e\u63a7\u5236\u94fe",
      "note": "dashboard can already trigger preview, run, and stop with real commands."
    },
    {
      "time": "\u4eca\u5929",
      "title": "Windows background service",
      "note": "After startup it stays alive in the Windows background and sends mail automatically at 9:00 every day."
    }
  ]
}
